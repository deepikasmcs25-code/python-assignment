a=int(input("Enter a first number: "))
b=int(input("Enter a second number: "))
print("________ARTHEMATIC OPERATION_______________")
print(f"ADDITION: {a}+{b}={a+b}")#Addition
print(f"SUBTRATION: {a}-{b}={a-b}")#Substraction
print(f"MULTIPLICATION: {a}*{b}={a*b}")#Multiplication
print(f"DIVISION: {a}/{b}={a/b}")#Division
print(f"REMAIDER/MODULUS: {a}%{b}={a%b}")#Modulus
print(f"EXPONENTIAL: {a}**{b}={a**b}")#Exponential
print(f"FLOOR DIVISIO: {a}//{b}={a//b}")#Floor Division
