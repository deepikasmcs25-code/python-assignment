n=int(input("Enter the number of rows: "))
for i in range (1,n):
    for j in range (i):
        print("*",end=" ")
    print()    

n=int(input("Enter the number of rows: "))
for i in range (n,0,-1):
    for j in range (i):
        print("*",end=" ")
    print()    #Print a pattern of stars in decreasing order


